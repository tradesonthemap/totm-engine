---
// Factory route: one page per client, generated from the data contract.
// Proves Pythonâ†’JSONâ†’Astro: Python emits clients.json; Astro renders deterministically.
import clients from '../data/clients.json';

export function getStaticPaths() {
  return clients.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props;

// Closed CODEâ†’component map demo (genome shape): unknown hero CODE = fail-loud at build.
const HEROES = { 'HERO-03': 'split-left', 'HERO-06': 'centered' };
const heroLayout = HEROES[c.dna.hero];
if (!heroLayout) throw new Error(`Unknown hero CODE ${c.dna.hero} for ${c.slug} â€” fail-closed`);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{c.business_name} â€” {c.trade}</title>
    <meta name="description" content={c.tagline} />
    <link rel="canonical" href={`https://totm-astro-pilot.pages.dev/${c.slug}/`} />
    <style define:vars={{ accent: c.dna.accent }}>
      :root { --accent: var(--accent); --ink: #14110c; --paper: #faf8f4; }
      * { box-sizing: border-box; }
      body { margin: 0; font: 17px/1.6 system-ui, sans-serif; color: var(--ink); background: var(--paper); }
      .hero { padding: 4rem 1.25rem; }
      .hero.split-left { border-left: 8px solid var(--accent); }
      .hero.centered { text-align: center; }
      h1 { font-size: 2.4rem; margin: 0 0 .5rem; }
      .tag { font-size: 1.2rem; color: #555; }
      .cta { display: inline-block; margin-top: 1.25rem; padding: .75rem 1.25rem; background: var(--accent); color: #111; font-weight: 600; text-decoration: none; border-radius: 6px; }
      ul { padding-left: 1.2rem; } main { max-width: 760px; margin: 0 auto; padding: 0 1.25rem 4rem; }
      footer { padding: 2rem 1.25rem; color: #777; font-size: .9rem; }
    </style>
  </head>
  <body>
    <section class={`hero ${heroLayout}`}>
      <main>
        <h1>{c.business_name}</h1>
        <p class="tag">{c.tagline}</p>
        <a class="cta" href={`tel:${c.business_number}`}>Call us</a>
      </main>
    </section>
    <main>
      <h2>What we do</h2>
      <ul>{c.services.map((s) => <li>{s}</li>)}</ul>
      <h2>Areas covered</h2>
      <p>{c.areas.join(' Â· ')}</p>
    </main>
    <footer>{c.business_name} Â· {c.trade} Â· family: {c.dna.family}</footer>
  </body>
</html>
